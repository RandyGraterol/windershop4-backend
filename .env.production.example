# ==========================================
# Configuración de Producción
# ==========================================
# IMPORTANTE: Copiar este archivo a .env.production y configurar con valores reales

# ==========================================
# Configuración del Servidor
# ==========================================
PORT=3000
NODE_ENV=production

# Base path para proxy reverso
BASE_PATH=/backendwinder

# ==========================================
# Configuración JWT
# ==========================================
# CAMBIAR ESTE SECRET EN PRODUCCIÓN
JWT_SECRET=CAMBIAR_ESTE_SECRET_POR_UNO_SEGURO_Y_ALEATORIO
JWT_EXPIRES_IN=24h

# ==========================================
# Base de Datos
# ==========================================
DATABASE_PATH=./database.sqlite

# ==========================================
# CORS
# ==========================================
# URL del frontend en producción
FRONTEND_URL=https://rifaslsv.com
